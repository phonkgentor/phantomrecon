# ==============================================================
# PhantomRecon -- Configuration
# ==============================================================
# Copy this file to .env and fill in your API keys

# ── AI Provider Selection ──────────────────────────────────────
# Choose your AI provider: groq, openai, anthropic, google, mistral, ollama, openrouter
AI_PROVIDER=groq
AI_MODEL=llama-3.3-70b-versatile

# ── LLM Provider API Keys ─────────────────────────────────────
# You only need ONE provider configured. The rest are optional.

# Groq (FREE tier — fast inference)
# Get key: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# OpenAI (paid — GPT-4o, GPT-4, GPT-3.5)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (paid — Claude 4, Claude 3.5)
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Google Gemini (FREE tier available — Gemini 2.5, 2.0, 1.5)
# Get key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Mistral AI (paid — Mistral Large, Medium, Codestral)
# Get key: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# OpenRouter (pay-per-use — access 200+ models)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Ollama (FREE — runs locally, no API key needed)
# Install: https://ollama.com
# Then run: ollama pull llama3.1:8b
OLLAMA_HOST=http://localhost:11434

# ── Security Tool API Keys ────────────────────────────────────

# Shodan (enriched port/service data)
# Get key: https://account.shodan.io
SHODAN_API_KEY=

# VirusTotal (domain reputation)
# Get key: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=

# SecurityTrails (historical DNS data)
# Get key: https://securitytrails.com/app/signup
SECURITYTRAILS_API_KEY=
